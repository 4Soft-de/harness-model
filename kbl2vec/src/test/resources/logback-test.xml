<configuration>
    <appender name="APP_LOG" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level [APP] %logger{36} - %msg %n</pattern>
        </encoder>
    </appender>

    <appender name="SYSTEM_LOG" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level [SYS] %logger{36} - %msg %n</pattern>
        </encoder>
    </appender>

    <appender name="ASYNC_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="SYSTEM_LOG"/>
        <queueSize>1000</queueSize>
    </appender>

    <logger name="com.foursoft.harness.kbl2vec.TRANSFORMATION_LOG" level="DEBUG" additivity="false">
        <appender-ref ref="APP_LOG"/>
    </logger>

    <logger name="com.foursoft.harness.kbl2vec.SYSTEM_LOG" level="WARN" additivity="false">
        <appender-ref ref="SYSTEM_LOG"/>
    </logger>

    <root level="warn">
        <appender-ref ref="ASYNC_CONSOLE"/>
    </root>
</configuration>