                           sh:maxCount  1;
                           sh:minCount  0;
                           sh:path      vec:wireReceptionSpecificationConductorCrimpShape
                         ];
        sh:property      [ sh:class     vec:NumericalValue;
                           sh:maxCount  1;
                           sh:minCount  0;
                           sh:path      vec:wireReceptionSpecificationConductorCrimpLegHeight
                         ];
